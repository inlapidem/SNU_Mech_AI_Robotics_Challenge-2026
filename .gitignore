# === 대용량 데이터 — git이 아닌 별도 채널로 옮김 ===
/yolo/
/datasets/
/runs/
/capture/
*.pt
*.onnx
*.onnx.data
*.engine
*.pth
*.trt
*.stale

# 학습된 모델 가중치는 포함 (팀원이 clone 후 바로 추론 가능)
# 단 .engine/.trt는 Jetson 기기에서 직접 빌드해야 하므로 제외 유지
!models/**/*.pt
!models/**/*.onnx
!models/**/*.onnx.data
!models/**/*.pth

# === Python 캐시/가상환경 ===
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.ipynb_checkpoints/

# === OS/에디터 잡파일 ===
.DS_Store
Thumbs.db
