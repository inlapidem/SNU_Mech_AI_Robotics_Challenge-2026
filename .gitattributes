# 모든 텍스트 파일은 LF로 통일 (WSL/Windows 에디터 ↔ Ubuntu 호환)
* text=auto eol=lf

# 셸/파이썬 스크립트는 반드시 LF (CRLF면 우분투에서 실행 깨짐)
*.sh text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.jsonl text eol=lf

# 바이너리 파일은 줄바꿈 변환 금지
*.png binary
*.jpg binary
*.jpeg binary
*.mp4 binary
*.pt binary
*.pth binary
*.onnx binary
*.engine binary
*.npy binary
*.npz binary
*.usd binary
*.usdz binary
